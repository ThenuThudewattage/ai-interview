# ──────────────────────────────────────────────────────────────
# AI Interview Intelligence Platform — Environment Variables
# Copy this file to .env and fill in real values.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aiinterview:aiinterview@localhost:5432/ai_interview
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-very-long-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM APIs ──────────────────────────────────────────────────
# Primary: Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Fallback: OpenRouter (optional)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=anthropic/claude-3-5-haiku

# Local: Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Embeddings ────────────────────────────────────────────────
GOOGLE_EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# ── App Settings ──────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Storage ───────────────────────────────────────────────────
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage
# For production S3:
# STORAGE_PROVIDER=s3
# S3_BUCKET=ai-interview-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_VECTOR_SEARCH=true
ENABLE_LEARNING_AGENT=true
ENABLE_RAG_CACHE=true

# ── Observability ─────────────────────────────────────────────
TRACING_ENABLED=false
METRICS_ENABLED=true
